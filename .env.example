# Odoo XML-RPC connection
ODOO_URL=https://your-odoo-host.example.com
ODOO_DB=your_database
ODOO_USERNAME=your_username
ODOO_PASSWORD=your_password_or_api_key
ODOO_TIMEOUT=20
ODOO_REPORT_TIMEOUT=300

# Local Flask server
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=false
MAX_UPLOAD_SIZE_MB=20
PRINT_QUEUE_DB_PATH=printed_parts.sqlite3

# Production server
PORT=8000
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=360
